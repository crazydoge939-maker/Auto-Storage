
-- Auto Tool Equip Script (Client-side)
-- Creates the GUI panel programmatically using Scale for responsive layout
-- Cycles through Tool names from itembutton1-40, equipping tools from Backpack/Character
-- If multiple tools share the same name, equips each one before moving to the next name

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ========================================================
-- GUI CREATION (all using Scale, independent ScreenGui)
-- ========================================================

-- Remove old GUI if it exists (prevent duplicates on respawn)
local oldGui = playerGui:FindFirstChild("AutoToolEquipGui")
if oldGui then
	oldGui.Parent = nil
end

-- Create standalone ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AutoToolEquipGui"
screenGui.ResetOnSpawn = false
screenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
screenGui.Parent = playerGui

-- Main Items Frame (draggable panel)
local itemsFrame = Instance.new("Frame")
itemsFrame.Name = "Items"
itemsFrame.Size = UDim2.new(0.25, 0, 0.5, 0)
itemsFrame.Position = UDim2.new(0.375, 0, 0.25, 0)
itemsFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
itemsFrame.BackgroundTransparency = 0.1
itemsFrame.BorderSizePixel = 2
itemsFrame.BorderColor3 = Color3.fromRGB(100, 100, 100)
itemsFrame.Parent = screenGui

-- Title Bar (also the drag handle)
local title = Instance.new("TextLabel")
title.Name = "Title"
title.Size = UDim2.new(1, 0, 0.06, 0)
title.Position = UDim2.new(0, 0, 0, 0)
title.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
title.Text = "Auto Tool Equip"
title.TextColor3 = Color3.fromRGB(255, 255, 255)
title.Font = Enum.Font.SourceSansBold
title.TextScaled = true
title.Parent = itemsFrame

-- Toggle Button
local toggleBtn = Instance.new("TextButton")
toggleBtn.Name = "ToggleButton"
toggleBtn.Size = UDim2.new(0.9, 0, 0.07, 0)
toggleBtn.Position = UDim2.new(0.05, 0, 0.07, 0)
toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
toggleBtn.Text = "AUTO EQUIP: OFF"
toggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
toggleBtn.Font = Enum.Font.SourceSansBold
toggleBtn.TextScaled = true
toggleBtn.BorderSizePixel = 2
toggleBtn.BorderColor3 = Color3.fromRGB(150, 150, 150)
toggleBtn.Parent = itemsFrame

-- ScrollingFrame
-- Grid container (no scroll, fixed grid 5x8)
local gridContainer = Instance.new("Frame")
gridContainer.Name = "ToolGrid"
gridContainer.Size = UDim2.new(0.92, 0, 0.83, 0)
gridContainer.Position = UDim2.new(0.04, 0, 0.16, 0)
gridContainer.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
gridContainer.BorderSizePixel = 1
gridContainer.BorderColor3 = Color3.fromRGB(80, 80, 80)
gridContainer.Parent = itemsFrame

-- UIGridLayout 5 columns x 8 rows
local gridLayout = Instance.new("UIGridLayout")
gridLayout.CellSize = UDim2.new(0.18, 0, 0.115, 0)
gridLayout.CellPadding = UDim2.new(0.01, 0, 0.01, 0)
gridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
gridLayout.VerticalAlignment = Enum.VerticalAlignment.Center
gridLayout.SortOrder = Enum.SortOrder.LayoutOrder
gridLayout.Parent = gridContainer

-- Table of button references
local itemButtons = {}

-- Create 40 item buttons (5 per row, 8 rows) as clickable TextButtons
for i = 1, 40 do
	local cell = Instance.new("TextButton")
	cell.Name = "itembutton" .. i
	cell.LayoutOrder = i
	cell.Text = ""
	cell.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	cell.BorderSizePixel = 1
	cell.BorderColor3 = Color3.fromRGB(70, 70, 70)
	cell.AutoButtonColor = true
	cell.Parent = gridContainer

	-- Number label at top
	local label = Instance.new("TextLabel")
	label.Name = "Index"
	label.Size = UDim2.new(1, 0, 0.3, 0)
	label.Position = UDim2.new(0, 0, 0, 0)
	label.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
	label.Text = tostring(i)
	label.TextColor3 = Color3.fromRGB(200, 200, 200)
	label.Font = Enum.Font.SourceSansBold
	label.TextScaled = true
	label.Parent = cell

	-- TextBox below the number
	local textBox = Instance.new("TextBox")
	textBox.Name = "ToolName"
	textBox.Size = UDim2.new(1, 0, 0.7, 0)
	textBox.Position = UDim2.new(0, 0, 0.3, 0)
	textBox.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
	textBox.Text = ""
	textBox.PlaceholderText = "..."
	textBox.PlaceholderColor3 = Color3.fromRGB(120, 120, 120)
	textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
	textBox.Font = Enum.Font.SourceSans
	textBox.TextScaled = true
	textBox.ClearTextOnFocus = false
	textBox.Parent = cell

	itemButtons[i] = cell
end

-- ========================================================
-- DRAG FUNCTIONALITY
-- ========================================================

local dragging = false
local dragStart = nil
local startPos = nil

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = itemsFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		itemsFrame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = false
	end
end)

-- ========================================================
-- TROLLMENU ITEM BUTTONS (the real buttons to click)
-- ========================================================

-- Find TrollMenu ScrollingFrame
local function getTrollScroll()
	local trollMenu = playerGui:FindFirstChild("TrollMenu")
	if not trollMenu then return nil end
	local items = trollMenu:FindFirstChild("Items")
	if not items then return nil end
	local scroll = items:FindFirstChild("ScrollingFrame")
	return scroll
end

-- Ensure itembutton1-40 exist in TrollMenu ScrollingFrame, return refs
local function ensureTrollButtons()
	local scroll = getTrollScroll()
	if not scroll then return {} end

	local buttons = {}
	for i = 1, 40 do
		local btn = scroll:FindFirstChild("itembutton" .. i)
		if not btn then
			btn = Instance.new("TextButton")
			btn.Name = "itembutton" .. i
			btn.Text = tostring(i)
			btn.Size = UDim2.new(0, 200, 0, 50)
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			btn.TextScaled = true
			btn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
			btn.BorderSizePixel = 0
			btn.Parent = scroll
		end
		buttons[i] = btn
	end
	return buttons
end

-- ========================================================
-- AUTO EQUIP LOGIC
-- ========================================================

local autoEquipActive = false
local equipThread = nil

-- Find all tools with a given name (case-insensitive)
local function findToolsByName(name)
	local tools = {}
	local nameLower = string.lower(name)
	local backpack = player:FindFirstChild("Backpack")
	local character = player.Character

	if backpack then
		for _, child in ipairs(backpack:GetChildren()) do
			if child:IsA("Tool") and string.lower(child.Name) == nameLower then
				table.insert(tools, child)
			end
		end
	end

	if character then
		for _, child in ipairs(character:GetChildren()) do
			if child:IsA("Tool") and string.lower(child.Name) == nameLower then
				table.insert(tools, child)
			end
		end
	end

	return tools
end

local function equipTool(tool)
	local character = player.Character
	if not character then return end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if not humanoid then return end
	humanoid:EquipTool(tool)
end

local function unequipAll()
	local character = player.Character
	if not character then return end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	if humanoid then
		humanoid:UnequipTools()
	end
end

-- Visual feedback on TrollMenu button: outline border
local function flashTrollButton(button, color)
	local origColor = button.BorderColor3
	local origSize = button.BorderSizePixel
	button.BorderColor3 = color
	button.BorderSizePixel = 4
	task.delay(0.4, function()
		if button and button.Parent then
			button.BorderColor3 = origColor
			button.BorderSizePixel = origSize
		end
	end)
end

-- Read Tool name from our panel for button index i
local function getToolNameForIndex(i)
	local btn = itemButtons[i]
	if not btn then return nil end
	local textBox = btn:FindFirstChild("ToolName")
	if not textBox or textBox.Text == "" then return nil end
	return textBox.Text
end

-- Activate a TrollMenu itembutton: equip the tool named in our panel
local function activateTrollButton(trollButton, buttonIndex, isAuto)
	local toolName = getToolNameForIndex(buttonIndex)
	if not toolName then return end

	local tools = findToolsByName(toolName)

	if #tools > 0 then
		-- Flash green border on the TrollMenu button
		flashTrollButton(trollButton, Color3.fromRGB(50, 255, 50))

		for _, tool in ipairs(tools) do
			if isAuto and not autoEquipActive then return end
			unequipAll()
			task.wait(0.15)
			equipTool(tool)
			task.wait(0.3)
		end
	else
		-- Flash red border (tool not found)
		flashTrollButton(trollButton, Color3.fromRGB(255, 50, 50))
		if isAuto then
			print("[AutoToolEquip] Tool not found: " .. toolName)
		end
	end
end

-- Main cycling loop: activates each TrollMenu itembutton that has a Tool name in our panel
local function runEquipCycle()
	while autoEquipActive do
		local trollButtons = ensureTrollButtons()

		for i = 1, 40 do
			if not autoEquipActive then return end

			local toolName = getToolNameForIndex(i)
			if toolName then
				local trollBtn = trollButtons[i]
				if trollBtn then
					print("[AutoToolEquip] Activating TrollMenu itembutton" .. i .. " for Tool: " .. toolName)
					activateTrollButton(trollBtn, i, true)
				end
			end

			task.wait(0.1)
		end

		task.wait(0.2)
	end
end

-- Toggle button handler
toggleBtn.MouseButton1Click:Connect(function()
	autoEquipActive = not autoEquipActive

	if autoEquipActive then
		toggleBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
		toggleBtn.Text = "AUTO EQUIP: ON"
		equipThread = task.spawn(function()
			runEquipCycle()
		end)
	else
		toggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
		toggleBtn.Text = "AUTO EQUIP: OFF"
		equipThread = nil
	end
end)

-- Manual click on our panel buttons also activates corresponding TrollMenu button
for i, btn in ipairs(itemButtons) do
	btn.MouseButton1Click:Connect(function()
		local trollButtons = ensureTrollButtons()
		local trollBtn = trollButtons[i]
		if trollBtn then
			activateTrollButton(trollBtn, i, false)
		end
	end)
end

-- Cleanup on character respawn
player.CharacterAdded:Connect(function()
	unequipAll()
end)
